{
	"organizeImports": {
		"enabled": true
	},
	"formatter": {
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineWidth": 100
	},
	"linter": {
		"rules": {
			"suspicious": {},
			"complexity": {
				"useArrowFunction": "info"
			},
			"style": {
				"noParameterAssign": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"files": {
		"ignore": ["node_modules", "dist"]
	}
}
